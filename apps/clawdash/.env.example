# Path to OpenClaw config directory
OPENCLAW_DIR=~/.openclaw

# Path to OpenClaw workspace
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# Agent ID to monitor
OPENCLAW_AGENT=main

# OpenClaw Gateway WebSocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Optional password for remote access (leave empty for local dev)
DASHBOARD_PASSWORD=
