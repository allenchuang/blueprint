# Google Analytics 4 — Measurement Protocol
# Get these from Google Analytics > Admin > Data Streams > Measurement Protocol API Secrets
# Measurement ID format: G-XXXXXXXXXX
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# API Secret: create one under your GA4 data stream's Measurement Protocol settings
EXPO_PUBLIC_GA_API_SECRET=your-api-secret-here

# Stripe (optional — app works without these, payments UI shows "not configured")
# Get keys from https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# API server URL for Stripe backend calls
EXPO_PUBLIC_API_URL=http://localhost:3001
# Apple Pay merchant identifier (required for Apple Pay, optional otherwise)
EXPO_PUBLIC_MERCHANT_IDENTIFIER=merchant.com.mastermind.app

# ElevenLabs Voice Agent (optional — voice agent screen shows "not configured" without this)
# Create an agent at https://elevenlabs.io/app/conversational-ai and copy the Agent ID
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=
