# Google Analytics 4
# Get your Measurement ID from Google Analytics > Admin > Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# World Mini App
# Get your App ID from https://developer.worldcoin.org
# Format: app_xxxxxxxxxx
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxx
# Developer Portal API key (server-side only, for verify/payment confirmation)
WORLD_APP_DEV_PORTAL_API_KEY=

# Stripe (optional — app works without these, payments UI shows "not configured")
# Get keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# API server URL for Stripe backend calls
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dynamic Auth (optional — app works without this, auth UI not rendered)
# Get your Environment ID from https://app.dynamic.xyz/dashboard/api
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Privy Auth (optional — alternative to Dynamic, auth UI not rendered without this)
# Get your App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional — App Client ID for multi-environment setups
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ElevenLabs Voice Agent (optional — voice agent page shows "not configured" without this)
# Create an agent at https://elevenlabs.io/app/conversational-ai and copy the Agent ID
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
