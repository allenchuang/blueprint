# Paperclip — AI Agent Orchestration
# Copy to .env and fill in values before running.

# Server port (default: 3100)
PORT=3100

# PostgreSQL connection string.
# Paperclip ships with an embedded Postgres that auto-starts when DATABASE_URL is unset.
# For production, point to an external Postgres instance:
# DATABASE_URL=postgres://user:password@host:5432/paperclip
DATABASE_URL=

# Set to "true" to serve the built UI from the server process.
# In development, leave as "false" — the UI is served by the Vite dev server.
SERVE_UI=false

# Deployment mode: "local" (default) | "cloud"
# PAPERCLIP_DEPLOYMENT_MODE=local

# Deployment exposure: "local" (default) | "network"
# PAPERCLIP_DEPLOYMENT_EXPOSURE=local

# Public base URL for auth callbacks (required when exposed beyond localhost)
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=http://localhost:3100

# Disable new user sign-up (set to "true" to lock the instance)
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# Secrets provider: "local" (default) | "aws-secrets-manager"
# PAPERCLIP_SECRETS_PROVIDER=local

# Storage provider: "local" (default) | "s3"
# PAPERCLIP_STORAGE_PROVIDER=local
# PAPERCLIP_STORAGE_LOCAL_DIR=~/.paperclip/storage

# S3 storage (only if PAPERCLIP_STORAGE_PROVIDER=s3)
# PAPERCLIP_STORAGE_S3_BUCKET=paperclip
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# PAPERCLIP_STORAGE_S3_ENDPOINT=
# PAPERCLIP_STORAGE_S3_PREFIX=

# Database backup settings
# PAPERCLIP_DB_BACKUP_ENABLED=false
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=7
