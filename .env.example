DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Dynamic Auth (optional — apps work without this)
# Get your Environment ID from https://app.dynamic.xyz/dashboard/api
DYNAMIC_ENVIRONMENT_ID=

# Privy Auth (optional — alternative to Dynamic, apps work without this)
# Get your App ID and App Secret from https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional — paste your verification key to skip API call for key fetch
PRIVY_VERIFICATION_KEY=

# Google Analytics (web app)
# Get your Measurement ID from Google Analytics > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
